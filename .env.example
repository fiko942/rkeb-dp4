ALMATRACE_PIN=085213
ALMATRACE_AUTH_SECRET=change-this-secret
ALMATRACE_DATA_MODE=live

ENRICHMENT_SEARCH_MAX_CANDIDATES=5

# Local Playwright worker pool.
LOCAL_BROWSER_MAX_WORKERS=2
LOCAL_BROWSER_IDLE_MS=5000
# Biarkan kosong untuk mode otomatis:
# - macOS: browser tampil
# - Linux: headless
# LOCAL_BROWSER_HEADLESS=
LOCAL_BROWSER_PROFILE_BASE_DIR=
# Biarkan kosong untuk channel otomatis:
# - macOS: chrome
# - Linux: chromium
# PLAYWRIGHT_BROWSER_CHANNEL=
PLAYWRIGHT_EXECUTABLE_PATH=
PLAYWRIGHT_LAUNCH_TIMEOUT_MS=15000

# Legacy disabled provider config. Not used in the default path anymore.
# BRAVE_SEARCH_API_KEY=
# GOOGLE_CSE_KEY=
# GOOGLE_CSE_CX=
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_ENGINE_ID=
